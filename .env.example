# DGX OpenAI-compatible endpoint
DGX_BASE_URL=http://192.168.12.243:30000/v1
DGX_MODEL=Qwen/Qwen3.5-35B-A3B-FP8
DGX_API_KEY=not-needed
DGX_TEMPERATURE_DEFAULT=0
DGX_MAX_TOKENS_DEFAULT=1600
DGX_REQUEST_TIMEOUT_SECONDS=180

# Mevzuat retrieval / embeddings
MILVUS_ENABLED=false
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=hukuk_chunks
EMBEDDING_BACKEND=hashing
EMBEDDING_BASE_URL=http://127.0.0.1:8081/v1
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT=30

# Judicial runtime
JUDICIAL_RUNTIME_ENABLED=false
JUDICIAL_PROCESSED_DIR=/Users/btmacstudio/Projects/yargi/_work/final_package/processed
JUDICIAL_EXACT_LOOKUP_PATH=/Users/btmacstudio/Projects/yargi/_work/final_package/processed/judicial_exact_lookup.sqlite
JUDICIAL_LEXICAL_INDEX_PATH=/Users/btmacstudio/Projects/yargi/_work/final_package/processed/judicial_lexical_index.sqlite
JUDICIAL_CHUNK_REFS_PATH=/Users/btmacstudio/Projects/yargi/_work/final_package/processed/judicial_exact_lookup.sqlite
LEGAL_ADVISOR_LLM_ENABLED=true
LEGAL_RAG_RETRIEVAL_TIMEOUT_MS=8000
LEGAL_RAG_LLM_TIMEOUT_MS=15000
LEGAL_RAG_VERIFICATION_TIMEOUT_MS=5000
LEGAL_RAG_MAX_TOTAL_EVIDENCE_CHARS=8000
LEGAL_RAG_MAX_SOURCE_CARDS=16
LEGAL_RAG_MAX_QUERY_CHARS=4000

# Guardrails (safe default scope)
GUARDRAILS_ENABLED=true
GUARDRAILS_STRICT_MODE=false
GUARDRAILS_CONFIG_DIR=guardrails
GUARDRAILS_LATENCY_LIMIT_MS=8000
GUARDRAILS_INPUT_MODERATION_ENABLED=true
HALLUCINATION_SAMPLES=3

# Presidio / KVKK
PRESIDIO_ENABLED=true
PRESIDIO_LANGUAGE=tr
PRESIDIO_ENTITIES=PERSON,PHONE_NUMBER,EMAIL_ADDRESS,LOCATION,TR_ID_NUMBER
PRESIDIO_MASK_CHAR=*
